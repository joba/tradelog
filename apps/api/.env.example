# ── Database ──────────────────────────────────────────────────
# Use a serverless-compatible Postgres provider.
# Recommended: Neon (https://neon.tech) or Supabase (https://supabase.com)
# Both offer free tiers and connection pooling suited for serverless.
#
# Neon example:
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/trade_journal?sslmode=require"
#
# Supabase — use the Transaction pooler URL (port 6543):
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── App ───────────────────────────────────────────────────────
NODE_ENV="production"
# Set to your Vercel frontend URL to restrict CORS:
CLIENT_URL="https://your-frontend.vercel.app"
